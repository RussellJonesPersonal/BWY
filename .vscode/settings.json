{
  // SASS compilation
  "liveSassCompile.settings.formats": [
    {
      "format": "expanded",
      "extensionName": ".css",
      "savePath": "/css"
    }
  ],

  // Prevent random compiled files cluttering explorer
  "files.exclude": {
    "**/.sass-cache": true
  },

  // Make sure VS Code formats nicely
  "editor.formatOnSave": true,

  // Ensure SCSS is recognised properly
  "emmet.includeLanguages": {
    "scss": "html"
  },

  // Optional but nice for sanity
  "editor.tabSize": 2,
  "editor.detectIndentation": false,

  // Prettier formatter
  "editor.defaultFormatter": "esbenp.prettier-vscode"
}
